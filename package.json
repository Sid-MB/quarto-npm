{
  "name": "@lillies/quarto",
  "version": "1.9.38",
  "description": "Distributes the Quarto CLI as an npm package. Run `npx @lillies/quarto` to use Quarto without a system install.",
  "keywords": ["quarto", "cli", "pandoc", "markdown", "publishing", "typst"],
  "license": "MIT",
  "homepage": "https://quarto.org",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sid-MB/quarto-npm.git"
  },
  "bugs": {
    "url": "https://github.com/Sid-MB/quarto-npm/issues"
  },
  "bin": {
    "quarto": "bin/quarto.js"
  },
  "files": [
    "bin/",
    "lib/",
    "scripts/",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node scripts/install.js"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
